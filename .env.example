# Telegram bot token from @BotFather — required
TELEGRAM_BOT_TOKEN=

# Gemini API key (https://aistudio.google.com/apikey) — required
GEMINI_API_KEY=

# Supabase project URL and service/anon key — required for chat logging,
# semantic memory, and live polls (https://supabase.com)
SUPABASE_URL=
SUPABASE_KEY=

# Tavily API key — optional, enables live web search (https://tavily.com)
TAVILY_API_KEY=

# Alpha Vantage API key — optional, enables stock/forex/commodity quotes
# (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=
